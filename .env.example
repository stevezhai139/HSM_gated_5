# =============================================================================
# HSM_gated — Environment Configuration Template
# =============================================================================
# 1. Copy this file to `.env` in the same directory:        cp .env.example .env
# 2. Fill in your local values below.
# 3. Load the variables before running scripts:              source .env
#    (or use python-dotenv to auto-load in Python)
#
# The `.env` file is git-ignored — never commit real credentials.
# =============================================================================

# ─── Native PostgreSQL (host system) ─────────────────────────────────────────
# Used by experiment_runner.py and shell scripts in code/setup/.
export HSM_DB_HOST=localhost
export HSM_DB_PORT=5432
export HSM_DB_NAME=tpch
export HSM_DB_USER=postgres
export HSM_DB_PASSWORD=

# ─── Docker PostgreSQL (memory-constrained 8GB container) ────────────────────
# Used by code/docker/* scripts and validation experiments
# (hsm_oltp_validation.py, hsm_burst_*_validation.py, hsm_job_*_validation.py).
# Default port 5433 keeps Docker isolated from the native instance on 5432.
export HSM_DOCKER_HOST=localhost
export HSM_DOCKER_PORT=5433
export HSM_DOCKER_USER=postgres
export HSM_DOCKER_PASSWORD=postgres
export HSM_DOCKER_DB=postgres

# ─── Auxiliary databases (inside the Docker container) ───────────────────────
export HSM_IMDB_DB=imdb

# =============================================================================
# SECURITY NOTE
# =============================================================================
# The default Docker password ("postgres") is suitable ONLY for local-only
# experiments where port 5433 is bound to 127.0.0.1 and the container is not
# exposed beyond the host. For any networked deployment, set a strong
# HSM_DOCKER_PASSWORD before running `docker compose up`.
# =============================================================================
